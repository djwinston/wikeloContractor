<Page
  x:Class="WikeloContractor.Views.Pages.InventoryPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:converters="clr-namespace:WikeloContractor.Views.Converters"
  xmlns:helpers="clr-namespace:WikeloContractor.Views.Helpers"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="InventoryPage"
  d:DataContext="{d:DesignInstance local:InventoryPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  ScrollViewer.CanContentScroll="False"
  mc:Ignorable="d">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    <!-- The thumb's own converters moved with it into Resources/ItemThumb.xaml -->
    <converters:ToUpperConverter x:Key="ToUpper" />
  </Page.Resources>

  <Page.InputBindings>
    <KeyBinding Key="Escape" Command="{Binding ViewModel.ClosePreviewCommand}" />
  </Page.InputBindings>

  <Grid>
  <Grid Margin="{StaticResource SpacingPagePadding}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <TextBlock
      Grid.Row="0"
      FontSize="{StaticResource FontSizeTitle}"
      FontWeight="Bold"
      Text="{DynamicResource Inventory_Title}" />

    <!-- Search + category filter -->
    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <ui:TextBox
        Grid.Column="0"
        Icon="{ui:SymbolIcon Search24}"
        PlaceholderText="{DynamicResource Inventory_SearchPlaceholder}"
        Text="{Binding ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

      <ComboBox
        Grid.Column="1"
        MinWidth="190"
        Margin="8,0,0,0"
        SelectedIndex="{Binding ViewModel.CategoryIndex, Mode=TwoWay}">
        <ComboBoxItem Content="{DynamicResource Catalog_Filter_AllCategories}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_OreMineral}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Armor}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Weapon}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Vehicle}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Component}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_CreatureMaterial}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Collectible}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Consumable}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Favor}" />
        <ComboBoxItem Content="{DynamicResource Inventory_Cat_Other}" />
      </ComboBox>
    </Grid>

    <!-- Empty state -->
    <TextBlock
      Grid.Row="2"
      Margin="0,24,0,0"
      HorizontalAlignment="Center"
      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
      Text="{DynamicResource Inventory_Empty}"
      Visibility="{Binding ViewModel.IsEmpty, Converter={StaticResource BoolToVisibility}}" />

    <!-- Item list, grouped by category -->
    <ScrollViewer
      Grid.Row="3"
      Margin="0,12,0,0"
      HorizontalScrollBarVisibility="Disabled"
      VerticalScrollBarVisibility="Auto">
      <ItemsControl Margin="0,0,16,0" ItemsSource="{Binding ViewModel.Items}">
        <ItemsControl.GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate>
                <TextBlock
                  Margin="0,18,0,11"
                  FontSize="12"
                  FontWeight="Bold"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  Text="{Binding Name, Converter={StaticResource ToUpper}}" />
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
          </GroupStyle>
        </ItemsControl.GroupStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border
              Margin="0,0,0,9"
              Padding="16,12"
              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource RadiusCard}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Item image: category icon until the configured image loads.
                     Shared with SourcingPage — see Resources/ItemThumb.xaml. -->
                <ContentControl
                  Grid.Column="0"
                  Margin="0,0,15,0"
                  Content="{Binding}"
                  ContentTemplate="{StaticResource ItemThumbTemplate}" />

                <!-- Name -->
                <TextBlock
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  FontSize="{StaticResource FontSizeBodyStrong}"
                  FontWeight="SemiBold"
                  Text="{Binding Name}"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="Wrap" />

                <!-- Editable counter: type a value directly (e.g. 100 / 1000) or step with the spin
                     buttons. Mono, because it is a quantity. An empty stock (0) is muted so a
                     glance down the list reads as "what do I still need". -->
                <ui:NumberBox
                  Grid.Column="2"
                  Width="110"
                  Margin="15,0,0,0"
                  VerticalAlignment="Center"
                  ClearButtonEnabled="False"
                  FontFamily="{StaticResource MonoFontFamily}"
                  MaxDecimalPlaces="0"
                  Minimum="0"
                  SmallChange="1"
                  SpinButtonPlacementMode="Inline"
                  ToolTip="{DynamicResource Inventory_CountTooltip}"
                  Value="{Binding Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                  <ui:NumberBox.Style>
                    <Style BasedOn="{StaticResource {x:Type ui:NumberBox}}" TargetType="ui:NumberBox">
                      <Style.Triggers>
                        <!-- Secondary, not tertiary: tertiary on the light theme's white row is
                             effectively invisible, and an unreadable count is worse than a weak
                             empty/non-empty contrast. -->
                        <DataTrigger Binding="{Binding Count}" Value="0">
                          <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ui:NumberBox.Style>
                </ui:NumberBox>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>

    <!-- Full-window item image preview; click anywhere or press Esc to close -->
    <Grid
      Background="#CC000000"
      Visibility="{Binding ViewModel.IsPreviewOpen, Converter={StaticResource BoolToVisibility}}">
      <Grid.InputBindings>
        <MouseBinding Command="{Binding ViewModel.ClosePreviewCommand}" MouseAction="LeftClick" />
      </Grid.InputBindings>
      <Image
        Margin="60"
        helpers:InventoryPreview.PreviewItemName="{Binding ViewModel.PreviewItemName}"
        RenderOptions.BitmapScalingMode="HighQuality"
        Stretch="Uniform" />
      <ui:Button
        Margin="0,24,24,0"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Command="{Binding ViewModel.ClosePreviewCommand}"
        Icon="{ui:SymbolIcon Dismiss24}" />
    </Grid>
  </Grid>
</Page>
