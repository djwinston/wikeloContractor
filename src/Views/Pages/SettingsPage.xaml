<Page
  x:Class="WikeloContractor.Views.Pages.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="SettingsPage"
  d:DataContext="{d:DesignInstance local:SettingsPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </Page.Resources>

  <StackPanel Margin="42,24" MaxWidth="600" HorizontalAlignment="Left">
    <TextBlock
      FontSize="28"
      FontWeight="DemiBold"
      Text="{DynamicResource Settings_Title}" />

    <TextBlock Margin="0,24,0,8" Text="{DynamicResource Settings_Language}" />
    <ComboBox SelectedIndex="{Binding ViewModel.LanguageIndex, Mode=TwoWay}">
      <ComboBoxItem Content="English" />
      <ComboBoxItem Content="Українська" />
    </ComboBox>

    <TextBlock Margin="0,24,0,8" Text="{DynamicResource Settings_Theme}" />
    <ComboBox SelectedIndex="{Binding ViewModel.ThemeIndex, Mode=TwoWay}">
      <ComboBoxItem Content="{DynamicResource Settings_Theme_System}" />
      <ComboBoxItem Content="{DynamicResource Settings_Theme_Light}" />
      <ComboBoxItem Content="{DynamicResource Settings_Theme_Dark}" />
    </ComboBox>

    <!-- Catalog data: game version, last sync, manual update fallback -->
    <TextBlock Margin="0,24,0,8" Text="{DynamicResource Settings_Data}" />
    <StackPanel Orientation="Horizontal">
      <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource Settings_Data_GameVersion}" />
      <TextBlock
        Margin="6,0,0,0"
        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
        Text="{Binding ViewModel.DataGameVersion}" />
    </StackPanel>
    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
      <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource Settings_Data_LastSync}" />
      <TextBlock
        Margin="6,0,0,0"
        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
        Text="{Binding ViewModel.DataLastSync}" />
    </StackPanel>
    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
      <ui:Button
        Command="{Binding ViewModel.CheckForUpdatesCommand}"
        Content="{DynamicResource Settings_Data_CheckNow}"
        Icon="{ui:SymbolIcon ArrowSync24}" />
      <ui:ProgressRing
        Width="20"
        Height="20"
        Margin="8,0,0,0"
        VerticalAlignment="Center"
        IsIndeterminate="True"
        Visibility="{Binding ViewModel.IsCheckingUpdates, Converter={StaticResource BoolToVisibility}}" />
    </StackPanel>
    <ui:InfoBar
      Margin="0,8,0,0"
      IsClosable="False"
      IsOpen="{Binding ViewModel.UpdateCheckFailed, Mode=OneWay}"
      Message="{DynamicResource Settings_Data_UpdateFailed}"
      Severity="Warning" />
    <ui:InfoBar
      Margin="0,8,0,0"
      Title="{DynamicResource Catalog_RateLimited_Title}"
      IsClosable="False"
      IsOpen="{Binding ViewModel.RateLimit.IsActive, Mode=OneWay}"
      Message="{Binding ViewModel.RateLimit.Message, Mode=OneWay}"
      Severity="Warning" />
  </StackPanel>
</Page>
