<Page
  x:Class="WikeloContractor.Views.Pages.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="SettingsPage"
  d:DataContext="{d:DesignInstance local:SettingsPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

  <StackPanel Margin="42,24" MaxWidth="600" HorizontalAlignment="Left">
    <TextBlock
      FontSize="28"
      FontWeight="DemiBold"
      Text="{DynamicResource Settings_Title}" />

    <TextBlock Margin="0,24,0,8" Text="{DynamicResource Settings_Language}" />
    <ComboBox SelectedIndex="{Binding ViewModel.LanguageIndex, Mode=TwoWay}">
      <ComboBoxItem Content="English" />
      <ComboBoxItem Content="Українська" />
    </ComboBox>

    <TextBlock Margin="0,24,0,8" Text="{DynamicResource Settings_Theme}" />
    <ComboBox SelectedIndex="{Binding ViewModel.ThemeIndex, Mode=TwoWay}">
      <ComboBoxItem Content="{DynamicResource Settings_Theme_System}" />
      <ComboBoxItem Content="{DynamicResource Settings_Theme_Light}" />
      <ComboBoxItem Content="{DynamicResource Settings_Theme_Dark}" />
    </ComboBox>

    <TextBlock
      Margin="0,32,0,0"
      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
      Text="{DynamicResource Settings_About}"
      TextWrapping="Wrap" />
  </StackPanel>
</Page>
