<Page
  x:Class="WikeloContractor.Views.Pages.AboutPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="AboutPage"
  d:DataContext="{d:DesignInstance local:AboutPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </Page.Resources>

  <StackPanel
    MaxWidth="620"
    Margin="{StaticResource SpacingPagePadding}"
    HorizontalAlignment="Left">
    <TextBlock
      FontSize="{StaticResource FontSizeTitle}"
      FontWeight="Bold"
      Text="{DynamicResource Nav_About}" />

    <!-- Brand hero. Composed here rather than shipped as a bitmap: the design calls for a light
         panel in the light theme and a dark one in the dark theme, so a single PNG cannot serve
         both, and two PNGs would need a runtime image swap. Built from the theme-swapped gradient
         plus the vector mark, it is theme-correct by construction, sharp at any DPI, and picks up
         new artwork automatically when BrandIcons.xaml is regenerated. -->
    <Border
      Height="290"
      Margin="0,18,0,0"
      Background="{DynamicResource AboutHeroBackgroundBrush}"
      BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
      BorderThickness="1"
      CornerRadius="12">
      <StackPanel VerticalAlignment="Center">
        <Border
          Width="92"
          Height="92"
          Background="{DynamicResource ChipRewardBackgroundBrush}"
          BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
          BorderThickness="2"
          CornerRadius="46">
          <Image
            Width="46"
            Height="46"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Source="{DynamicResource AppMarkThemed}" />
        </Border>
        <TextBlock
          Margin="0,14,0,0"
          HorizontalAlignment="Center"
          FontSize="30"
          FontWeight="ExtraBold"
          Text="{DynamicResource App_Name}" />
        <TextBlock
          Margin="0,8,0,0"
          HorizontalAlignment="Center"
          FontFamily="{StaticResource MonoFontFamily}"
          FontSize="10"
          FontWeight="SemiBold"
          Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
          Text="{DynamicResource About_Tagline}" />
      </StackPanel>
    </Border>

    <TextBlock
      Margin="0,18,0,0"
      FontSize="{StaticResource FontSizeBody}"
      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
      Text="{DynamicResource Settings_About}"
      TextWrapping="Wrap" />

    <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
      <TextBlock
        FontSize="{StaticResource FontSizeBody}"
        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
        Text="{DynamicResource Settings_AppVersion}" />
      <TextBlock
        Margin="6,0,0,0"
        FontSize="{StaticResource FontSizeBody}"
        FontWeight="SemiBold"
        Text="{Binding ViewModel.AppVersion, Mode=OneWay}" />
    </StackPanel>

    <!-- Tech stack. The technology names are proper nouns (like item/ship names) and stay English;
         only the label is localized. -->
    <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
      <TextBlock
        FontSize="{StaticResource FontSizeBody}"
        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
        Text="{DynamicResource Settings_BuiltWith}" />
      <TextBlock
        Margin="6,0,0,0"
        FontSize="{StaticResource FontSizeBody}"
        FontWeight="SemiBold"
        Text=".NET 10  ·  C#  ·  WPF  ·  WPF-UI (Fluent)" />
    </StackPanel>

    <!-- Self-update (Velopack): manual check + restart-to-apply -->
    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
      <ui:Button
        Command="{Binding ViewModel.CheckAppUpdateCommand}"
        Content="{DynamicResource Settings_AppUpdate_Check}"
        Icon="{ui:SymbolIcon ArrowDownload24}" />
      <ui:ProgressRing
        Width="20"
        Height="20"
        Margin="8,0,0,0"
        VerticalAlignment="Center"
        IsIndeterminate="True"
        Visibility="{Binding ViewModel.IsAppUpdateBusy, Converter={StaticResource BoolToVisibility}}" />
    </StackPanel>
    <ui:InfoBar
      Margin="0,8,0,0"
      IsClosable="False"
      IsOpen="{Binding ViewModel.HasAppUpdateMessage, Mode=OneWay}"
      Message="{Binding ViewModel.AppUpdateMessage, Mode=OneWay}"
      Severity="Informational" />
    <ui:Button
      Margin="0,8,0,0"
      Command="{Binding ViewModel.RestartForAppUpdateCommand}"
      Content="{DynamicResource Settings_AppUpdate_Restart}"
      Icon="{ui:SymbolIcon ArrowClockwise24}"
      Visibility="{Binding ViewModel.IsAppUpdateReady, Converter={StaticResource BoolToVisibility}}" />

    <!-- Required credit per Star Citizen Wiki API terms of use -->
    <TextBlock
      Margin="0,20,0,0"
      FontSize="{StaticResource FontSizeCaption}"
      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
      TextWrapping="Wrap">
      <Run Text="{DynamicResource Settings_Attribution}" />
      <!-- An inline Hyperlink keeps WPF's stock blue, which is near-invisible on the dark theme's
           surface; the theme's accent-text brush is the themed equivalent. -->
      <Hyperlink
        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
        NavigateUri="https://api.star-citizen.wiki"
        RequestNavigate="OnAttributionLinkNavigate">api.star-citizen.wiki</Hyperlink>
    </TextBlock>

    <TextBlock
      Margin="0,10,0,0"
      FontSize="{StaticResource FontSizeCaption}"
      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
      Text="{DynamicResource Settings_Disclaimer}"
      TextWrapping="Wrap" />
  </StackPanel>
</Page>
