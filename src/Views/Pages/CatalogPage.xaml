<Page
  x:Class="WikeloContractor.Views.Pages.CatalogPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:controls="clr-namespace:WikeloContractor.Views.Controls"
  xmlns:converters="clr-namespace:WikeloContractor.Views.Converters"
  xmlns:helpers="clr-namespace:WikeloContractor.Views.Helpers"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="CatalogPage"
  d:DataContext="{d:DesignInstance local:CatalogPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  ScrollViewer.CanContentScroll="False"
  mc:Ignorable="d">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    <converters:CategoryToSymbolConverter x:Key="CategoryToSymbol" />
    <converters:PresenceToVisibilityConverter x:Key="NullToVisibility" Invert="True" />
  </Page.Resources>

  <Grid Margin="{StaticResource SpacingPagePadding}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header: title + refresh -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock
        Grid.Column="0"
        FontSize="{StaticResource FontSizeTitle}"
        FontWeight="Bold"
        Text="{DynamicResource Catalog_Title}" />

      <!-- Sync status: green cloud-check when the data matches the current LIVE version. The
           version itself is mono — it is a technical value, per docs/design-system.md. -->
      <StackPanel
        Grid.Column="1"
        VerticalAlignment="Center"
        Orientation="Horizontal">
        <ui:SymbolIcon
          VerticalAlignment="Center"
          FontSize="15"
          Foreground="{DynamicResource SystemFillColorSuccessBrush}"
          Symbol="CloudCheckmark16"
          Visibility="{Binding ViewModel.IsSynced, Converter={StaticResource BoolToVisibility}}" />
        <ui:SymbolIcon
          VerticalAlignment="Center"
          FontSize="15"
          Foreground="{DynamicResource SystemFillColorCautionBrush}"
          Symbol="CloudOff24"
          Visibility="{Binding ViewModel.IsOffline, Converter={StaticResource BoolToVisibility}}" />
        <!-- No syncing state here: the shell overlay covers this page whenever a sync is running,
             so a badge for it could never be seen. See MainWindow.xaml. -->
        <TextBlock
          Margin="6,0,0,0"
          Foreground="{DynamicResource SystemFillColorSuccessBrush}"
          Style="{StaticResource MonoCaptionStyle}"
          Text="{Binding ViewModel.GameVersion}" />
      </StackPanel>
    </Grid>

    <!-- Wikelo reputation standing: rank + progress toward the next rank -->
    <Border
      Grid.Row="1"
      Margin="0,16,0,0"
      Padding="16,11"
      Background="{DynamicResource ReputationBannerBrush}"
      BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
      BorderThickness="2,0,0,0"
      CornerRadius="0,8,8,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <ui:SymbolIcon
            VerticalAlignment="Center"
            FontSize="15"
            Symbol="Trophy24" />
          <TextBlock
            Margin="8,0,0,0"
            VerticalAlignment="Center"
            FontSize="{StaticResource FontSizeBody}"
            FontWeight="SemiBold"
            Text="{Binding ViewModel.Reputation.TierLabel}" />
        </StackPanel>

        <ProgressBar
          Grid.Column="1"
          Height="5"
          Margin="16,0"
          VerticalAlignment="Center"
          Maximum="1"
          Minimum="0"
          Value="{Binding ViewModel.Reputation.Fraction, Mode=OneWay}" />

        <TextBlock
          Grid.Column="2"
          Style="{StaticResource MonoCaptionStyle}"
          Text="{Binding ViewModel.Reputation.ProgressText}" />
      </Grid>
    </Border>

    <!-- Filters: search, reward category, required resource -->
    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <ui:TextBox
        Grid.Column="0"
        Icon="{ui:SymbolIcon Search24}"
        PlaceholderText="{DynamicResource Catalog_Search}"
        Text="{Binding ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

      <ComboBox
        Grid.Column="1"
        MinWidth="170"
        Margin="8,0,0,0"
        SelectedIndex="{Binding ViewModel.CategoryIndex, Mode=TwoWay}">
        <ComboBoxItem Content="{DynamicResource Catalog_Filter_AllCategories}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Ships}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Vehicles}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Paints}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Weapons}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Armor}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Other}" />
      </ComboBox>

      <ComboBox
        Grid.Column="2"
        MinWidth="190"
        Margin="8,0,0,0"
        ItemsSource="{Binding ViewModel.ResourceOptions}"
        SelectedIndex="{Binding ViewModel.ResourceIndex, Mode=TwoWay}" />

      <ui:Button
        Grid.Column="3"
        Margin="8,0,0,0"
        VerticalAlignment="Stretch"
        Command="{Binding ViewModel.ClearFiltersCommand}"
        Icon="{ui:SymbolIcon Dismiss24}"
        ToolTip="{DynamicResource Catalog_ClearFilters}" />
    </Grid>

    <!-- Status messages -->
    <StackPanel Grid.Row="3" Margin="0,12,0,0">
      <ui:InfoBar
        Title="{DynamicResource Catalog_LoadError_Title}"
        IsClosable="False"
        IsOpen="{Binding ViewModel.HasLoadError, Mode=OneWay}"
        Message="{DynamicResource Catalog_LoadError_Message}"
        Severity="Error" />
      <ui:InfoBar
        Title="{DynamicResource Catalog_Offline_Title}"
        IsClosable="False"
        IsOpen="{Binding ViewModel.IsOffline, Mode=OneWay}"
        Message="{DynamicResource Catalog_Offline_Message}"
        Severity="Warning" />
      <ui:InfoBar
        Title="{DynamicResource Catalog_RateLimited_Title}"
        IsClosable="True"
        IsOpen="{Binding ViewModel.RateLimit.IsActive, Mode=TwoWay}"
        Message="{Binding ViewModel.RateLimit.Message, Mode=OneWay}"
        Severity="Warning" />
      <!-- First-start initialization: version check + catalog fetch -->
      <StackPanel Margin="0,24,0,0" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibility}}">
        <ProgressBar
          Width="280"
          HorizontalAlignment="Center"
          IsIndeterminate="True" />
        <TextBlock
          Margin="0,12,0,0"
          HorizontalAlignment="Center"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{DynamicResource Catalog_Loading}" />
      </StackPanel>
      <TextBlock
        Margin="0,24,0,0"
        HorizontalAlignment="Center"
        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
        Text="{DynamicResource Catalog_Empty}"
        Visibility="{Binding ViewModel.IsEmpty, Converter={StaticResource BoolToVisibility}}" />
    </StackPanel>

    <!-- Contract list -->
    <ScrollViewer
      Grid.Row="4"
      Margin="0,12,0,0"
      HorizontalScrollBarVisibility="Disabled"
      VerticalScrollBarVisibility="Auto">
      <ItemsControl Margin="0,0,16,0" ItemsSource="{Binding ViewModel.Contracts}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <!-- Outer border draws only the hairline row divider (design 3a/3b: rows are separated
                 by a rule, not by card chrome). The completed state lives on the inner border so
                 its left accent and wash do not fight the divider's thickness. -->
            <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
              <Border Cursor="Hand">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="0,8,8,0" />
                    <!-- Reserve the 2 px left accent in every row (transparent until completed) plus
                         a 12 px inset before the thumb. Completed state then only swaps colours — no
                         layout shift, and nothing sits in negative-margin space (the earlier
                         Margin="-12,0" pushed the accent into the gutter, where the ScrollViewer
                         clipped it, so it never showed). -->
                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Padding" Value="12,15" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource CompletedRowWashBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource CompletedRowAccentBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Border.InputBindings>
                  <MouseBinding
                    Command="{Binding ViewModel.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                    CommandParameter="{Binding Contract}"
                    MouseAction="LeftClick" />
                </Border.InputBindings>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <!-- Reward preview: image from the disk cache, category icon until it loads -->
                  <Border
                    Grid.Column="0"
                    Width="{StaticResource SizeCatalogThumbWidth}"
                    Height="{StaticResource SizeCatalogThumbHeight}"
                    Margin="0,0,14,0"
                    VerticalAlignment="Top"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <!-- A Border does not clip its child to the corner radius (ClipToBounds only
                         clips to the rectangle), so the artwork needs an explicit rounded clip or
                         it renders square corners over the rounded thumb. -->
                    <Grid>
                      <Grid.Clip>
                        <RectangleGeometry
                          RadiusX="8"
                          RadiusY="8"
                          Rect="0,0,120,80" />
                      </Grid.Clip>
                      <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Symbol="{Binding Contract.Category, Converter={StaticResource CategoryToSymbol}}"
                        Visibility="{Binding Source, ElementName=PreviewImage, Converter={StaticResource NullToVisibility}}" />
                      <Image
                        x:Name="PreviewImage"
                        helpers:RewardPreview.Contract="{Binding Contract}"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Stretch="Uniform" />
                    </Grid>
                  </Border>

                  <StackPanel Grid.Column="1">
                    <!-- Title line: name, category tag, completed marker -->
                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                      <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeSubtitle}"
                        FontWeight="SemiBold"
                        Text="{Binding Contract.Title}"
                        TextTrimming="CharacterEllipsis" />
                      <ContentControl
                        Margin="9,0,0,0"
                        Content="{Binding CategoryLabel}"
                        Style="{StaticResource TagStyle}" />
                      <controls:StatusBadge
                        Margin="9,0,0,0"
                        Role="Success"
                        Symbol="Checkmark24"
                        Text="{DynamicResource Contract_Completed}"
                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}" />
                      <!-- Everything gathered but not yet turned in — caution role, so it reads as
                           a different state from the green completed badge. -->
                      <controls:StatusBadge
                        Margin="9,0,0,0"
                        Role="Caution"
                        Symbol="CheckmarkCircle24"
                        Text="{DynamicResource Contract_ReadyBadge}"
                        Visibility="{Binding ShowReadyBadge, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <!-- Readiness: how much of the requirement list the inventory already covers.
                         Hidden once completed — the items were spent, so the bar is meaningless. -->
                    <StackPanel
                      Margin="0,0,0,10"
                      Orientation="Horizontal"
                      ToolTip="{DynamicResource Contract_ReadinessTooltip}"
                      Visibility="{Binding ShowReadiness, Converter={StaticResource BoolToVisibility}}">
                      <ProgressBar
                        Width="360"
                        Style="{StaticResource ReadinessBarStyle}"
                        Value="{Binding ReadinessFraction, Mode=OneWay}" />
                      <TextBlock
                        Margin="10,0,0,0"
                        Style="{StaticResource MonoCaptionStyle}"
                        Text="{Binding ReadinessLabel}" />
                    </StackPanel>

                    <!-- Required items, colored by availability vs the inventory. Chips wrap;
                         they are never trimmed, so a 20-requirement contract makes a tall row. -->
                    <ItemsControl
                      Margin="0,0,0,3"
                      ItemsPanel="{StaticResource ChipWrapPanel}"
                      ItemsSource="{Binding RequirementChips}"
                      ItemTemplate="{StaticResource RequirementChipTemplate}" />

                    <!-- Rewards and blueprints share one line, behind a REWARDS label -->
                    <WrapPanel>
                      <TextBlock
                        Margin="0,0,8,6"
                        Style="{StaticResource OverlineTextStyle}"
                        Text="{DynamicResource Catalog_RewardsLabel}" />
                      <ItemsControl ItemsPanel="{StaticResource ChipWrapPanel}" ItemsSource="{Binding Contract.Rewards}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <ContentControl
                              Background="{DynamicResource ChipRewardBackgroundBrush}"
                              BorderBrush="{DynamicResource ChipRewardBorderBrush}"
                              Foreground="{DynamicResource ChipRewardForegroundBrush}"
                              Style="{StaticResource ChipStyle}">
                              <TextBlock FontWeight="Medium" Text="{Binding Name}" />
                            </ContentControl>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <!-- Blueprints granted, abbreviated; an empty source renders nothing -->
                      <ItemsControl ItemsPanel="{StaticResource ChipWrapPanel}" ItemsSource="{Binding Contract.Blueprints}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <ContentControl Style="{StaticResource BlueprintChipStyle}">
                              <TextBlock FontWeight="SemiBold"><Run Text="{DynamicResource Catalog_BlueprintAbbrev}" /><Run Text=" · " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                            </ContentControl>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </WrapPanel>
                  </StackPanel>

                  <!-- XP awarded + the completion toggle, centred against the row -->
                  <StackPanel
                    Grid.Column="2"
                    Margin="14,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                      Margin="0,0,0,10"
                      HorizontalAlignment="Right"
                      FontSize="{StaticResource FontSizeBody}"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource XpBadgeForegroundBrush}"
                      Text="{Binding XpLabel}" />
                    <!-- Compact ghost toggle, per design 3a: 6/12 padding, thin outline, small
                         SemiBold caption, muted text; a hollow circle for "not done yet" (the
                         checkmark is reserved for the COMPLETED badge) flipping to an undo arrow. -->
                    <ui:Button
                      HorizontalAlignment="Right"
                      Padding="12,6"
                      Appearance="Secondary"
                      FontSize="{StaticResource FontSizeCaption}"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                      Command="{Binding ToggleCompletedCommand}"
                      Visibility="{Binding ShowCompletionToggle, Converter={StaticResource BoolToVisibility}}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                          <Setter Property="Content" Value="{DynamicResource Contract_MarkDone}" />
                          <Setter Property="Icon" Value="{ui:SymbolIcon Circle24}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                              <Setter Property="Content" Value="{DynamicResource Contract_Reopen}" />
                              <Setter Property="Icon" Value="{ui:SymbolIcon ArrowUndo24}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                    </ui:Button>
                  </StackPanel>
                </Grid>
              </Border>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>
</Page>
