<Page
  x:Class="WikeloContractor.Views.Pages.FavoritesPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="FavoritesPage"
  d:DataContext="{d:DesignInstance local:FavoritesPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  ScrollViewer.CanContentScroll="False"
  mc:Ignorable="d">

  <!-- The catalog, narrowed to starred contracts. The rows come from the shared
       ContractCardTemplate and the filters bind the same ContractListViewModel members the catalog
       binds — only the header and the empty states are page-specific. -->

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </Page.Resources>

  <Grid Margin="{StaticResource SpacingPagePadding}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Orientation="Horizontal">
      <ui:SymbolIcon
        VerticalAlignment="Center"
        FontSize="20"
        Filled="True"
        Foreground="{DynamicResource FavoriteStarBrush}"
        Symbol="Star28" />
      <TextBlock
        Margin="10,0,0,0"
        FontSize="{StaticResource FontSizeTitle}"
        FontWeight="Bold"
        Text="{DynamicResource Favorites_Title}" />
    </StackPanel>

    <!-- Filters: search, reward category, required resource — identical to the catalog's -->
    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <ui:TextBox
        Grid.Column="0"
        Icon="{ui:SymbolIcon Search24}"
        PlaceholderText="{DynamicResource Catalog_Search}"
        Text="{Binding ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

      <ComboBox
        Grid.Column="1"
        MinWidth="170"
        Margin="8,0,0,0"
        SelectedIndex="{Binding ViewModel.CategoryIndex, Mode=TwoWay}">
        <ComboBoxItem Content="{DynamicResource Catalog_Filter_AllCategories}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Ships}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Vehicles}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Paints}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Weapons}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Armor}" />
        <ComboBoxItem Content="{DynamicResource Catalog_Cat_Other}" />
      </ComboBox>

      <ComboBox
        Grid.Column="2"
        MinWidth="190"
        Margin="8,0,0,0"
        ItemsSource="{Binding ViewModel.ResourceOptions}"
        SelectedIndex="{Binding ViewModel.ResourceIndex, Mode=TwoWay}" />

      <ui:Button
        Grid.Column="3"
        Margin="8,0,0,0"
        VerticalAlignment="Stretch"
        Command="{Binding ViewModel.ClearFiltersCommand}"
        Icon="{ui:SymbolIcon Dismiss24}"
        ToolTip="{DynamicResource Catalog_ClearFilters}" />
    </Grid>

    <!-- Two distinct empty states: nothing starred at all, vs. starred contracts that the
         filters exclude. They are mutually exclusive, so both can live here. -->
    <StackPanel Grid.Row="2" Margin="0,12,0,0">
      <StackPanel
        Margin="0,40,0,0"
        Visibility="{Binding ViewModel.HasNoFavorites, Converter={StaticResource BoolToVisibility}}">
        <!-- Outline star, matching the un-starred toggle: "nothing here yet", not "disabled". -->
        <ui:SymbolIcon
          HorizontalAlignment="Center"
          FontSize="32"
          Foreground="{DynamicResource TextFillColorTertiaryBrush}"
          Symbol="Star28" />
        <TextBlock
          Margin="0,12,0,0"
          HorizontalAlignment="Center"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{DynamicResource Favorites_Empty}"
          TextAlignment="Center"
          TextWrapping="Wrap" />
      </StackPanel>
      <TextBlock
        Margin="0,24,0,0"
        HorizontalAlignment="Center"
        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
        Text="{DynamicResource Catalog_Empty}"
        Visibility="{Binding ViewModel.IsEmpty, Converter={StaticResource BoolToVisibility}}" />
    </StackPanel>

    <!-- Contract list -->
    <ScrollViewer
      Grid.Row="3"
      Margin="0,12,0,0"
      HorizontalScrollBarVisibility="Disabled"
      VerticalScrollBarVisibility="Auto">
      <ItemsControl
        Margin="0,0,16,0"
        ItemsSource="{Binding ViewModel.Contracts}"
        ItemTemplate="{StaticResource ContractCardTemplate}" />
    </ScrollViewer>

  </Grid>
</Page>
