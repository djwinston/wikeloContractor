<ui:FluentWindow
  x:Class="WikeloContractor.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:WikeloContractor.Views"
  xmlns:pages="clr-namespace:WikeloContractor.Views.Pages"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="{DynamicResource App_Title}"
  Width="1100"
  Height="680"
  MinWidth="800"
  MinHeight="500"
  d:DataContext="{d:DesignInstance local:MainWindow, IsDesignTimeCreatable=False}"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  ExtendsContentIntoTitleBar="True"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  WindowBackdropType="Mica"
  WindowCornerPreference="Round"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d">

  <ui:FluentWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </ui:FluentWindow.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Icon is set in code-behind: it adapts to the active theme (light icon on dark theme and vice versa) -->
    <ui:TitleBar
      x:Name="TitleBarControl"
      Title="{DynamicResource App_Title}"
      Grid.Row="0" />

    <!-- Locked while catalog data is syncing: see MainWindowViewModel.IsNavigationEnabled for why
         the whole shell is held rather than each page guarding itself. The TitleBar above is
         outside this element, so closing the window is never blocked. -->
    <ui:NavigationView
      x:Name="RootNavigation"
      Grid.Row="1"
      IsBackButtonVisible="Collapsed"
      IsEnabled="{Binding ViewModel.IsNavigationEnabled}"
      IsPaneToggleVisible="True"
      OpenPaneLength="160"
      PaneDisplayMode="Left">

      <ui:NavigationView.MenuItems>
        <ui:NavigationViewItem
          Content="{DynamicResource Nav_Catalog}"
          Icon="{ui:SymbolIcon ClipboardTaskListLtr24}"
          TargetPageType="{x:Type pages:CatalogPage}" />
        <ui:NavigationViewItem
          Content="{DynamicResource Nav_Inventory}"
          Icon="{ui:SymbolIcon Box24}"
          TargetPageType="{x:Type pages:InventoryPage}" />
      </ui:NavigationView.MenuItems>

      <ui:NavigationView.FooterMenuItems>
        <ui:NavigationViewItem
          Content="{DynamicResource Nav_Settings}"
          Icon="{ui:SymbolIcon Settings24}"
          TargetPageType="{x:Type pages:SettingsPage}" />
        <ui:NavigationViewItem
          Content="{DynamicResource Nav_About}"
          Icon="{ui:SymbolIcon Info24}"
          TargetPageType="{x:Type pages:AboutPage}" />
      </ui:NavigationView.FooterMenuItems>

    </ui:NavigationView>

    <!-- Sync lock. Same row as the NavigationView and declared after it, so it covers the whole
         shell — nav pane included — while catalog data is incomplete. Placed here rather than on
         the Catalog page because IsEnabled on the NavigationView cascades into its content: a
         page-hosted overlay would be greyed out along with everything it is explaining.
         Determinate: the service reports real per-phase counts. -->
    <Border
      Grid.Row="1"
      Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
      Visibility="{Binding ViewModel.IsSyncing, Converter={StaticResource BoolToVisibility}}">
      <StackPanel
        MaxWidth="380"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <!-- WPF-UI's own spinner rather than a hand-rolled RotateTransform storyboard: a
             Style-based one cannot work here (Storyboard.TargetName is rejected inside a Style),
             and the control already owns its animation. Indeterminate because it says "working";
             how far along we are is the determinate bar below, which has real counts. -->
        <ui:ProgressRing
          Width="42"
          Height="42"
          HorizontalAlignment="Center"
          IsIndeterminate="True" />
        <TextBlock
          Margin="0,14,0,0"
          HorizontalAlignment="Center"
          FontSize="{StaticResource FontSizeSubtitle}"
          FontWeight="SemiBold"
          Text="{DynamicResource Catalog_Syncing_Title}" />
        <TextBlock
          Margin="0,8,0,0"
          HorizontalAlignment="Center"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{DynamicResource Catalog_Syncing_Hint}"
          TextAlignment="Center"
          TextWrapping="Wrap" />
        <ProgressBar
          Height="{StaticResource SizeProgressBarHeight}"
          Margin="0,20,0,0"
          Maximum="1"
          Minimum="0"
          Value="{Binding ViewModel.SyncFraction, Mode=OneWay}" />
        <TextBlock
          Margin="0,10,0,0"
          HorizontalAlignment="Center"
          Style="{StaticResource MonoCaptionStyle}"
          Text="{Binding ViewModel.SyncProgressText}" />
      </StackPanel>
    </Border>
  </Grid>
</ui:FluentWindow>
