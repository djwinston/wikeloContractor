<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


  <!-- App-specific colours for the LIGHT theme. Same keys as Brand.Dark.xaml — the two are swapped
       as a pair by ApplicationHostService.ApplyTheme, so a key added to one MUST be added to the
       other or it silently resolves to nothing in that theme.

       Light is a separate palette, not the dark one inverted: the accent is darker (#0D95B5), and
       chip fills are pale washes with saturated text rather than bright pills. See
       docs/design-system.md. -->

  <Color x:Key="BrandAccentColor">#0D95B5</Color>

  <!-- Light-theme legibility corrections. The ONLY place the project overrides a Fluent token,
       and deliberately so: measured on the real light surface (#F9F9F9), Fluent's secondary text
       renders #A6A6A6 (2.4:1 contrast) and its default control stroke #EAEAEA (1.1:1) — the
       outline tag's border came out identical to the page and was invisible. Both fail WCAG AA.
       Dark is unaffected and Brand.Dark.xaml intentionally does NOT redeclare these: swapping the
       palette removes this dictionary, so Fluent's own dark values (which measure fine, 590 units
       of contrast) come back on their own. This is the documented exception to the
       "same keys in both files" rule — see docs/design-system.md.

       Opaque on purpose, not alpha over black: these must render exactly as specified, including
       on top of the reputation banner and the completed-row wash. -->
  <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#5B5B5B" />
  <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#6E6E6E" />
  <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#B8B8B8" />

  <!-- Neutral requirement chip resolves from the Fluent theme (ControlFillColorSecondaryBrush) —
       see the note in Brand.Dark.xaml. Kept out of the brand palette deliberately. -->

  <!-- Requirement chip: partially covered by the inventory -->
  <SolidColorBrush x:Key="ChipCautionBackgroundBrush" Color="#FBF1D9" />
  <SolidColorBrush x:Key="ChipCautionBorderBrush" Color="#EDDCAE" />
  <SolidColorBrush x:Key="ChipCautionForegroundBrush" Color="#8A6410" />
  <SolidColorBrush x:Key="ChipCautionValueBrush" Color="#6B4E0A" />

  <!-- Requirement chip: fully covered -->
  <SolidColorBrush x:Key="ChipSuccessBackgroundBrush" Color="#E2F3EA" />
  <SolidColorBrush x:Key="ChipSuccessBorderBrush" Color="#BFE3CE" />
  <SolidColorBrush x:Key="ChipSuccessForegroundBrush" Color="#2E8259" />
  <SolidColorBrush x:Key="ChipSuccessValueBrush" Color="#1F6244" />

  <!-- Reward chip: the cyan accent role -->
  <SolidColorBrush x:Key="ChipRewardBackgroundBrush" Color="#E2F4F9" />
  <SolidColorBrush x:Key="ChipRewardBorderBrush" Color="#BFE6EF" />
  <SolidColorBrush x:Key="ChipRewardForegroundBrush" Color="#0D7490" />

  <!-- Blueprint role: solid purple outline -->
  <SolidColorBrush x:Key="ChipBlueprintBackgroundBrush" Color="#F1ECFD" />
  <SolidColorBrush x:Key="ChipBlueprintBorderBrush" Color="#B9A6EF" />
  <SolidColorBrush x:Key="ChipBlueprintForegroundBrush" Color="#6B47C9" />

  <!-- XP badge (contract reputation award) -->
  <SolidColorBrush x:Key="XpBadgeForegroundBrush" Color="#9A6C0C" />

  <!-- Completed catalog row: left marker plus a fade-out wash across the row -->
  <SolidColorBrush x:Key="CompletedRowAccentBrush" Color="#2E8259" />
  <LinearGradientBrush x:Key="CompletedRowWashBrush" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Offset="0" Color="#142E8259" />
    <GradientStop Offset="0.55" Color="#002E8259" />
  </LinearGradientBrush>

  <!-- Reputation banner above the contract list -->
  <LinearGradientBrush x:Key="ReputationBannerBrush" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Offset="0" Color="#1F0D95B5" />
    <GradientStop Offset="1" Color="#000D95B5" />
  </LinearGradientBrush>

  <!-- About page hero panel: a branded glow behind the mark and wordmark -->
  <RadialGradientBrush
    x:Key="AboutHeroBackgroundBrush"
    Center="0.5,0.12"
    GradientOrigin="0.5,0.12"
    RadiusX="1.2"
    RadiusY="0.95">
    <GradientStop Offset="0" Color="#DFF1F8" />
    <GradientStop Offset="0.45" Color="#EEF5F9" />
    <GradientStop Offset="1" Color="#F7F9FB" />
  </RadialGradientBrush>

</ResourceDictionary>
