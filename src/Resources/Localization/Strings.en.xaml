<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <sys:String x:Key="App_Title">Wikelo Contractor</sys:String>

  <sys:String x:Key="Nav_Catalog">Catalog</sys:String>
  <sys:String x:Key="Nav_Favorites">Favorites</sys:String>
  <sys:String x:Key="Nav_Inventory">Inventory</sys:String>
  <sys:String x:Key="Nav_Sourcing">Where to Find</sys:String>
  <sys:String x:Key="Nav_Settings">Settings</sys:String>
  <sys:String x:Key="Nav_About">About</sys:String>

  <sys:String x:Key="Catalog_Title">Wikelo Contracts</sys:String>
  <sys:String x:Key="Catalog_Search">Search contracts...</sys:String>
  <sys:String x:Key="Catalog_Filter_AllCategories">All categories</sys:String>
  <sys:String x:Key="Catalog_Filter_AllResources">All resources</sys:String>
  <sys:String x:Key="Catalog_Cat_Ships">Ships</sys:String>
  <sys:String x:Key="Catalog_Cat_Vehicles">Ground vehicles</sys:String>
  <sys:String x:Key="Catalog_Cat_Paints">Paints &amp; liveries</sys:String>
  <sys:String x:Key="Catalog_Cat_Weapons">Weapons</sys:String>
  <sys:String x:Key="Catalog_Cat_Armor">Armor</sys:String>
  <sys:String x:Key="Catalog_Cat_Other">Other</sys:String>
  <sys:String x:Key="Catalog_ClearFilters">Clear filters</sys:String>
  <sys:String x:Key="Catalog_BlueprintAbbrev">BP</sys:String>
  <sys:String x:Key="Catalog_Empty">No contracts match the filters.</sys:String>
  <sys:String x:Key="Catalog_LoadError_Title">Failed to load contracts</sys:String>
  <sys:String x:Key="Catalog_LoadError_Message">Check your internet connection and try again.</sys:String>
  <sys:String x:Key="Catalog_Offline_Title">Offline data</sys:String>
  <sys:String x:Key="Catalog_Offline_Message">Could not refresh the catalog — showing previously cached contracts.</sys:String>
  <sys:String x:Key="Catalog_Loading">Loading the contract catalog...</sys:String>
  <sys:String x:Key="Catalog_Syncing_Title">Syncing catalog data</sys:String>
  <sys:String x:Key="Catalog_Syncing_Hint">Fetching contract data from the Star Citizen Wiki API. The app stays locked until this finishes, so nothing acts on half-loaded data.</sys:String>
  <sys:String x:Key="Catalog_Syncing_Contracts">Loading contract details — {0} of {1}</sys:String>
  <sys:String x:Key="Catalog_Syncing_Rewards">Loading rewards — {0} of {1}</sys:String>
  <sys:String x:Key="Catalog_RateLimited_Title">Too many requests</sys:String>
  <sys:String x:Key="Catalog_RateLimited_Retry">The Star Citizen Wiki API allows a limited number of requests per minute. Loading resumes in {0} s.</sys:String>
  <sys:String x:Key="Catalog_RateLimited_Resuming">Resuming loading...</sys:String>
  <sys:String x:Key="Catalog_RateLimited_Exhausted">The API is still limiting requests. Showing cached contracts — try Settings → Check for updates in a few minutes.</sys:String>

  <!-- Wikelo reputation standing + contract completion. Rank names are game standings (English). -->
  <sys:String x:Key="Reputation_Tier_New">New Customer</sys:String>
  <sys:String x:Key="Reputation_Tier_VeryGood">Very Good Customer</sys:String>
  <sys:String x:Key="Reputation_Tier_VeryBest">Very Best Customer</sys:String>
  <sys:String x:Key="Reputation_Progress">{0} / {1} XP</sys:String>
  <sys:String x:Key="Reputation_Max">{0} XP · Max rank</sys:String>
  <sys:String x:Key="Contract_MarkDone">Mark done</sys:String>
  <sys:String x:Key="Contract_Completed">Completed</sys:String>
  <sys:String x:Key="Contract_Ready">Ready to turn in</sys:String>
  <sys:String x:Key="Contract_ReadyBadge">Ready</sys:String>
  <sys:String x:Key="Contract_ReadinessTooltip">Required items you already have in your inventory</sys:String>
  <sys:String x:Key="Contract_Reopen">Reopen</sys:String>
  <sys:String x:Key="Contract_AddFavorite">Add to favorites</sys:String>
  <sys:String x:Key="Contract_RemoveFavorite">Remove from favorites</sys:String>

  <!-- Favorites page: the catalog filtered to starred contracts. The "nothing starred" copy is
       deliberately separate from Catalog_Empty ("filters matched nothing") — different situations. -->
  <sys:String x:Key="Favorites_Title">Favorites</sys:String>
  <sys:String x:Key="Favorites_Empty">No favorites yet. Tap the star on a contract to keep it here.</sys:String>
  <sys:String x:Key="Catalog_RewardsLabel">REWARDS</sys:String>
  <!-- {0} is the reputation the contract awards; the UI calls it XP (see docs/design-system.md) -->
  <sys:String x:Key="Catalog_XpBadge">+{0} XP</sys:String>
  <sys:String x:Key="Dialog_Cancel">Cancel</sys:String>
  <sys:String x:Key="Complete_Dialog_Title">Complete contract?</sys:String>
  <sys:String x:Key="Complete_Dialog_Message">These items will be deducted from your inventory:</sys:String>
  <sys:String x:Key="Complete_Dialog_Confirm">Complete &amp; deduct</sys:String>
  <sys:String x:Key="Uncomplete_Dialog_Title">Reopen contract?</sys:String>
  <sys:String x:Key="Uncomplete_Dialog_Message">The items spent to complete this contract were already removed from your inventory and will not be restored. Update your inventory manually if needed. Items that were deducted:</sys:String>
  <sys:String x:Key="Uncomplete_Dialog_Confirm">Reopen</sys:String>

  <sys:String x:Key="Details_Back">Back to the catalog</sys:String>
  <sys:String x:Key="Details_OnceOnly">One-time contract</sys:String>
  <sys:String x:Key="Details_Prerequisites">Has prerequisites</sys:String>
  <sys:String x:Key="Details_Blueprints">Blueprints</sys:String>
  <sys:String x:Key="Details_OpenWiki">Open on the wiki</sys:String>
  <sys:String x:Key="Details_OpenPledge">Pledge store page</sys:String>
  <sys:String x:Key="Details_Requirements">Required items</sys:String>
  <sys:String x:Key="Details_Rewards">Rewards</sys:String>
  <sys:String x:Key="Details_RewardsPending">Reward details are still loading — check back in a moment.</sys:String>
  <!-- Reward stat labels (design 1c): short label shown above the value in the stat grid. Values
       with units (SCU, m/s, $, %, °C) are composed in code and kept English. -->
  <sys:String x:Key="Details_StatLabel_Cargo">Cargo</sys:String>
  <sys:String x:Key="Details_StatLabel_Crew">Crew</sys:String>
  <sys:String x:Key="Details_StatLabel_Hull">Hull HP</sys:String>
  <sys:String x:Key="Details_StatLabel_Shields">Shields</sys:String>
  <sys:String x:Key="Details_StatLabel_Speed">Speed</sys:String>
  <sys:String x:Key="Details_StatLabel_Msrp">MSRP</sys:String>
  <sys:String x:Key="Details_StatLabel_Temp">Temp °C</sys:String>
  <sys:String x:Key="Details_StatLabel_Radiation">Radiation</sys:String>
  <sys:String x:Key="Details_StatLabel_RadiationScrub">Rad. scrub</sys:String>
  <!-- Damage-resistance type labels (armor stat grid) -->
  <sys:String x:Key="Damage_Impact">Impact</sys:String>
  <sys:String x:Key="Damage_Physical">Physical</sys:String>
  <sys:String x:Key="Damage_Energy">Energy</sys:String>
  <sys:String x:Key="Damage_Distortion">Distortion</sys:String>
  <sys:String x:Key="Damage_Thermal">Thermal</sys:String>
  <sys:String x:Key="Damage_Biochem">Biochem</sys:String>
  <sys:String x:Key="Damage_Stun">Stun</sys:String>
  <sys:String x:Key="Details_Stat_Missiles">Missiles × {0}</sys:String>
  <!-- Overline labels: uppercase in the resource because WPF has no text-transform -->
  <sys:String x:Key="Details_Loadout_Weapons">WEAPONS</sys:String>
  <sys:String x:Key="Details_Loadout_Components">COMPONENTS</sys:String>
  <sys:String x:Key="Details_Comp_PowerPlant">Power plant</sys:String>
  <sys:String x:Key="Details_Comp_Shield">Shield</sys:String>
  <sys:String x:Key="Details_Comp_Cooler">Cooler</sys:String>
  <sys:String x:Key="Details_Comp_QuantumDrive">Quantum drive</sys:String>
  <sys:String x:Key="Details_Comp_JumpDrive">Jump drive</sys:String>

  <sys:String x:Key="Inventory_Title">My Inventory</sys:String>
  <sys:String x:Key="Inventory_SearchPlaceholder">Search items…</sys:String>
  <sys:String x:Key="Inventory_Empty">No items yet — required items from the catalog will appear here.</sys:String>
  <sys:String x:Key="Inventory_CountTooltip">Type a quantity or use the up/down arrows</sys:String>
  <sys:String x:Key="Inventory_Cat_OreMineral">Ores &amp; minerals</sys:String>
  <sys:String x:Key="Inventory_Cat_Armor">Armor</sys:String>
  <sys:String x:Key="Inventory_Cat_Weapon">Weapons</sys:String>
  <sys:String x:Key="Inventory_Cat_Vehicle">Vehicles</sys:String>
  <sys:String x:Key="Inventory_Cat_Component">Components</sys:String>
  <sys:String x:Key="Inventory_Cat_CreatureMaterial">Creature materials</sys:String>
  <sys:String x:Key="Inventory_Cat_Collectible">Collectibles</sys:String>
  <sys:String x:Key="Inventory_Cat_Consumable">Consumables</sys:String>
  <sys:String x:Key="Inventory_Cat_Favor">Favor &amp; scrip</sys:String>
  <sys:String x:Key="Inventory_Cat_Other">Other</sys:String>

  <!-- Sourcing reference ("where to find"): the inventory item set with authored notes -->
  <sys:String x:Key="Sourcing_Title">Where to Find</sys:String>
  <sys:String x:Key="Sourcing_Subtitle">Where to source every item Wikelo asks for. Notes are community-sourced — correct them in sourcing-notes.json.</sys:String>
  <sys:String x:Key="Sourcing_SearchPlaceholder">Search items or sources…</sys:String>
  <sys:String x:Key="Sourcing_Empty">No items match the filters.</sys:String>
  <sys:String x:Key="Sourcing_NoNote">No sourcing note yet.</sys:String>
  <sys:String x:Key="Sourcing_Back">Back to the list</sys:String>
  <sys:String x:Key="Sourcing_WhereToFind">WHERE TO FIND IT</sys:String>
  <sys:String x:Key="Sourcing_HowToObtain">HOW TO OBTAIN IT</sys:String>
  <sys:String x:Key="Sourcing_GuidePlaceholder">A step-by-step guide for this item has not been written yet.</sys:String>

  <sys:String x:Key="Settings_Title">Settings</sys:String>
  <sys:String x:Key="Settings_Language">Language</sys:String>
  <sys:String x:Key="Settings_Theme">Theme</sys:String>
  <sys:String x:Key="Settings_Theme_System">System</sys:String>
  <sys:String x:Key="Settings_Theme_Light">Light</sys:String>
  <sys:String x:Key="Settings_Theme_Dark">Dark</sys:String>
  <sys:String x:Key="Settings_Data">Catalog data</sys:String>
  <sys:String x:Key="Settings_Data_ApiVersion">API version:</sys:String>
  <sys:String x:Key="Settings_Data_LastSync">Last synced:</sys:String>
  <sys:String x:Key="Settings_Data_CheckNow">Check for updates</sys:String>
  <sys:String x:Key="Settings_Data_UpdateFailed">Could not reach the API — showing cached data. Try again later.</sys:String>
  <!-- Product name: a brand, deliberately identical in both languages -->
  <sys:String x:Key="App_Name">Wikelo Contractor</sys:String>
  <!-- Hero overline; uppercase in the resource because WPF has no text-transform -->
  <sys:String x:Key="About_Tagline">CONTRACT CATALOG  ·  INVENTORY MANAGER</sys:String>
  <sys:String x:Key="Settings_About">Wikelo Contractor — a companion app for Wikelo trades in Star Citizen.</sys:String>
  <sys:String x:Key="Settings_AppVersion">App version:</sys:String>
  <sys:String x:Key="Settings_BuiltWith">Built with:</sys:String>
  <sys:String x:Key="Settings_AppUpdate">Application updates</sys:String>
  <sys:String x:Key="Settings_AppUpdate_Check">Check for app updates</sys:String>
  <sys:String x:Key="Settings_AppUpdate_Checking">Checking for updates…</sys:String>
  <sys:String x:Key="Settings_AppUpdate_UpToDate">You have the latest version.</sys:String>
  <sys:String x:Key="Settings_AppUpdate_Downloading">Downloading update…</sys:String>
  <sys:String x:Key="Settings_AppUpdate_Ready">Update {0} is ready. Restart to apply it.</sys:String>
  <sys:String x:Key="Settings_AppUpdate_Restart">Restart to update</sys:String>
  <sys:String x:Key="Settings_AppUpdate_Failed">Could not check for updates. Try again later.</sys:String>
  <sys:String x:Key="Settings_Attribution">Game data is provided by the Star Citizen Wiki API:</sys:String>
  <sys:String x:Key="Settings_Disclaimer">Unofficial fan-made app, not affiliated with or endorsed by Cloud Imperium Games. All game data belongs to Cloud Imperium Games.</sys:String>

</ResourceDictionary>
