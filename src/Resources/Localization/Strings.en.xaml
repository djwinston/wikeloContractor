<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <sys:String x:Key="App_Title">Wikelo Contractor</sys:String>

  <sys:String x:Key="Nav_Catalog">Catalog</sys:String>
  <sys:String x:Key="Nav_Inventory">Inventory</sys:String>
  <sys:String x:Key="Nav_Settings">Settings</sys:String>

  <sys:String x:Key="Catalog_Title">Wikelo Contracts</sys:String>
  <sys:String x:Key="Catalog_Placeholder">The contract catalog will appear here (Phase 2).</sys:String>

  <sys:String x:Key="Inventory_Title">My Inventory</sys:String>
  <sys:String x:Key="Inventory_Placeholder">Your collected resources will appear here (Phase 3).</sys:String>

  <sys:String x:Key="Settings_Title">Settings</sys:String>
  <sys:String x:Key="Settings_Language">Language</sys:String>
  <sys:String x:Key="Settings_Theme">Theme</sys:String>
  <sys:String x:Key="Settings_Theme_System">System</sys:String>
  <sys:String x:Key="Settings_Theme_Light">Light</sys:String>
  <sys:String x:Key="Settings_Theme_Dark">Dark</sys:String>
  <sys:String x:Key="Settings_About">Wikelo Contractor — a companion app for Wikelo trades in Star Citizen.</sys:String>

</ResourceDictionary>
