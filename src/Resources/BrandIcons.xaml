<!--
  Vector app mark for the in-app title bar, so it stays crisp at any DPI instead of
  downscaling a PNG. Geometry is `docs/brand/icon-vector-24.svg`: outer ring + mask + eyes,
  with the inner ring and the nose line dropped.

  That rung is chosen because the ui:TitleBar icon slot is 16 logical px. The full composition
  (docs/brand/icon-vector-dark.svg) puts a second ring 14 units inside the first and a 6-unit
  nose line, neither of which resolves at that size — they turn to mud. The eyes are kept:
  they are what makes the mark recognizable rather than a generic ring.

  Key names describe the ARTWORK, matching Assets/icon.png (dark) and icon-light.png (light):
  AppMarkDark is the navy mark for light surfaces, AppMarkLight the cyan one for dark surfaces.
-->
<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <DrawingImage x:Key="AppMarkDark">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing>
          <GeometryDrawing.Geometry>
            <EllipseGeometry Center="100,100" RadiusX="92" RadiusY="92" />
          </GeometryDrawing.Geometry>
          <GeometryDrawing.Pen>
            <Pen Brush="#1CA7C4" Thickness="10" />
          </GeometryDrawing.Pen>
        </GeometryDrawing>

        <GeometryDrawing Brush="#16324A" Geometry="M100,34 L125.9,50.5 L137.7,81.1 L133,116.5 L116.5,151.9 L100,166 L83.5,151.9 L67,116.5 L62.3,81.1 L74.1,50.5 Z" />

        <GeometryDrawing Brush="#F7FDFF">
          <GeometryDrawing.Geometry>
            <RectangleGeometry RadiusX="4" RadiusY="4" Rect="64,88,24,12" />
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
        <GeometryDrawing Brush="#F7FDFF">
          <GeometryDrawing.Geometry>
            <RectangleGeometry RadiusX="4" RadiusY="4" Rect="112,88,24,12" />
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <DrawingImage x:Key="AppMarkLight">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing>
          <GeometryDrawing.Geometry>
            <EllipseGeometry Center="100,100" RadiusX="92" RadiusY="92" />
          </GeometryDrawing.Geometry>
          <GeometryDrawing.Pen>
            <Pen Brush="#2DD4E8" Thickness="10" />
          </GeometryDrawing.Pen>
        </GeometryDrawing>

        <GeometryDrawing Geometry="M100,34 L125.9,50.5 L137.7,81.1 L133,116.5 L116.5,151.9 L100,166 L83.5,151.9 L67,116.5 L62.3,81.1 L74.1,50.5 Z">
          <GeometryDrawing.Brush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Offset="0" Color="#8CEFFF" />
              <GradientStop Offset="0.6" Color="#2FC1DE" />
              <GradientStop Offset="1" Color="#14425C" />
            </LinearGradientBrush>
          </GeometryDrawing.Brush>
        </GeometryDrawing>

        <!-- Navy eyes, not white: on the bright gradient white measures 1.9:1 and washes out,
             navy gives 6.9:1. Matches docs/brand/icon-vector-light.svg. -->
        <GeometryDrawing Brush="#16324A">
          <GeometryDrawing.Geometry>
            <RectangleGeometry RadiusX="4" RadiusY="4" Rect="64,88,24,12" />
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
        <GeometryDrawing Brush="#16324A">
          <GeometryDrawing.Geometry>
            <RectangleGeometry RadiusX="4" RadiusY="4" Rect="112,88,24,12" />
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

</ResourceDictionary>
