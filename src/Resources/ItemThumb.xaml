<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="clr-namespace:WikeloContractor.Views.Converters"
  xmlns:helpers="clr-namespace:WikeloContractor.Views.Helpers"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

  <!-- The 46x46 rounded item thumb, shared by InventoryPage and SourcingPage. Its DataContext needs
       a `Name` (string) and a `Category` (InventoryCategory) — both InventoryItemViewModel and
       SourcingItemViewModel expose exactly that.

       Clicking the artwork opens the full-window preview through the hosting page's
       `ViewModel.OpenPreviewCommand`, so every page using this template must expose that command. -->

  <converters:InventoryCategoryToSymbolConverter x:Key="ThumbCategoryToSymbol" />
  <converters:PresenceToVisibilityConverter x:Key="ThumbNullToVisibility" Invert="True" />

  <DataTemplate x:Key="ItemThumbTemplate">
    <Border
      Width="{StaticResource SizeInventoryThumb}"
      Height="{StaticResource SizeInventoryThumb}"
      VerticalAlignment="Center"
      Background="{DynamicResource ControlFillColorSecondaryBrush}"
      CornerRadius="8">
      <!-- Border does not clip to its corner radius; without this the artwork renders
           square corners over the rounded thumb (same as the catalog row). -->
      <Grid>
        <Grid.Clip>
          <RectangleGeometry
            RadiusX="8"
            RadiusY="8"
            Rect="0,0,46,46" />
        </Grid.Clip>
        <ui:SymbolIcon
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="20"
          Foreground="{DynamicResource TextFillColorTertiaryBrush}"
          Symbol="{Binding Category, Converter={StaticResource ThumbCategoryToSymbol}}"
          Visibility="{Binding Source, ElementName=ThumbImage, Converter={StaticResource ThumbNullToVisibility}}" />
        <Image
          x:Name="ThumbImage"
          helpers:InventoryPreview.ItemName="{Binding Name}"
          Cursor="Hand"
          RenderOptions.BitmapScalingMode="HighQuality"
          Stretch="Uniform">
          <!-- A null-Source image is not hit-tested, so imageless rows are not clickable. Keep the
               binding on the Image itself — moving it to the Border would make every row clickable,
               including the ones with no artwork to preview. -->
          <Image.InputBindings>
            <MouseBinding
              Command="{Binding ViewModel.OpenPreviewCommand, RelativeSource={RelativeSource AncestorType=Page}}"
              CommandParameter="{Binding Name}"
              MouseAction="LeftClick" />
          </Image.InputBindings>
        </Image>
      </Grid>
    </Border>
  </DataTemplate>

</ResourceDictionary>
