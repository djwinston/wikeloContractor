<Application
  x:Class="WikeloContractor.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  DispatcherUnhandledException="OnDispatcherUnhandledException"
  Exit="OnExit"
  Startup="OnStartup">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Dark" />
        <ui:ControlsDictionary />
        <ResourceDictionary Source="pack://application:,,,/Resources/BrandIcons.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/Typography.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/Metrics.xaml" />
        <!-- Default brand palette; ApplicationHostService.ApplyTheme swaps this dictionary at
             runtime, paired with the WPF-UI theme above -->
        <ResourceDictionary Source="pack://application:,,,/Resources/Theme/Brand.Dark.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/Chips.xaml" />
        <!-- After Chips.xaml: the shared catalog row resolves the chip styles via StaticResource,
             which only looks backwards through the merged dictionaries -->
        <ResourceDictionary Source="pack://application:,,,/Resources/ContractCard.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/ItemThumb.xaml" />
        <!-- Default language; LocalizationService swaps this dictionary at runtime -->
        <ResourceDictionary Source="pack://application:,,,/Resources/Localization/Strings.en.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
